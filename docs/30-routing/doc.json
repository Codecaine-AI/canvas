        {
          "insert": "getConnectionAnchors",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/connection-overlay.ts",
              "symbol": "getConnectionAnchors"
            }
          }
        },
        {
          "insert": " (from upstream "
        },
        {
          "insert": "getAnchors",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ") and "
        },
        {
          "insert": "resolveConnectionCascade",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/connection-overlay.ts",
              "symbol": "resolveConnectionCascade"
            }
          }
        },
        {
          "insert": " (from upstream "
        },
        {
          "insert": "ConnectionOverlay.renderConnector",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "'s decision cascade). Both are algorithm-only ports: no canvas-paint, no "
        },
        {
          "insert": "GfxController",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/grid search, and no rotation support — this repo renders the overlay in React (CanvasStage) from this module's pure return values."
        }
      ],
      "children": []
    },
    "b-routing-overlay-p2-16": {
      "id": "b-routing-overlay-p2-16",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "getConnectionAnchors",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
