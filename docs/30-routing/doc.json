    "b-routing-elbow-p1-4": {
      "id": "b-routing-elbow-p1-4",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "When a connection's style is "
        },
        {
          "insert": "elbow",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "routeConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "routeConnection"
            }
          }
        },
        {
          "insert": " first tries "
        },
        {
          "insert": "routeOrthogonalAStar",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "routeOrthogonalAStar"
            }
          }
        },
        {
          "insert": ", which delegates the actual pathfinding to "
        },
        {
          "insert": "PathGenerator.generateOrthogonalConnectorPath",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/path-generator.ts",
              "symbol": "PathGenerator"
            }
          }
        },
        {
          "insert": " — an A* pathfinder adapted from BlockSuite (an MPL-2.0 licensed open-source project) that searches an orthogonal (axis-aligned, right-angle-turn-only) grid built around the two endpoint bounds and any other obstacle bounds supplied. Obstacle bounds are built from the caller-supplied "
        },
        {
          "insert": "obstacles",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " list (typically every other object in the document), with the two endpoint objects' own owners and their container-ancestor chain excluded via "
        },
        {
          "insert": "collectAncestorIds",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "collectAncestorIds"
            }
          }
        },
        {
          "insert": " — a connection touching a nested object necessarily passes through its parent containers' bounds, which is containment rather than an obstacle crossing to be routed around. If the A* generator throws or returns fewer than 2 usable points, routing falls back to "
        },
        {
          "insert": "routeElbow",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "routeElbow"
            }
          }
        },
        {
          "insert": ", a simpler stub-and-midpoint elbow construction with no obstacle awareness."
        }
      ],
      "children": []
    },
    "b-routing-elbow-p2-5": {
      "id": "b-routing-elbow-p2-5",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The A* algorithm itself lives under "
