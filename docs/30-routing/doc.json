    "b-routing-overlay-p1-15": {
      "id": "b-routing-overlay-p1-15",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "packages/canvas/src/routing/connection-overlay.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/connection-overlay.ts"
