          "insert": " is verbatim with import specifiers rewritten to point at the local "
        },
        {
          "insert": "graph.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "priority-queue.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "gfx-types.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/gfx-types.ts"
            }
          }
        },
        {
          "insert": ". "
        },
        {
          "insert": "path-generator.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/path-generator.ts"
            }
          }
        },
        {
          "insert": " is explicitly not verbatim — it's a labeled extraction of only the pure, framework-free orthogonal path-generation logic ("
        },
        {
          "insert": "PathGenerator",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and its supporting helpers) from BlockSuite's "
        },
        {
          "insert": "connector-manager.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", with Lit, signals, "
        },
        {
          "insert": "GfxController",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/model, and canvas-paint/overlay code stripped out, and no rotation support (this repo's object schema has no per-object rotation field). "
        },
        {
          "insert": "gfx-types.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/gfx-types.ts"
