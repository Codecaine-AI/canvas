    "b-routing-intro-2": {
      "id": "b-routing-intro-2",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A connection's visual path is never stored as a fixed drawing — it is computed from the current geometry of its two endpoint objects every time either side moves. "
        },
        {
          "insert": "routeConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "routeConnection"
            }
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/canvas/src/routing/routing.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts"
            }
          }
        },
        {
          "insert": " is the single entry point: given a from-object, a to-object, and a connection's own style/anchor/waypoint overrides, it returns a "
        },
        {
          "insert": "RoutedConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/routing.ts",
              "symbol": "RoutedConnection"
            }
          }
        },
        {
          "insert": " — an SVG path string, the true start/end anchor points, a label placement point, and (for polyline styles) the route's world-space vertex list. Four connection styles branch out of this one function: solid/dotted straight lines, "
        },
        {
          "insert": "smooth",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " cubic curves, explicit "
        },
        {
          "insert": "waypoints",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " polylines, and "
        },
        {
          "insert": "elbow",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " orthogonal routing — the last of which is the most involved, and is the focus of this doc."
        }
      ],
      "children": []
    },
    "b-routing-heading-elbow-3": {
      "id": "b-routing-heading-elbow-3",
      "flavour": "heading",
      "props": {
        "level": 2
      },
