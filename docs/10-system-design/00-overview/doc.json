      "props": {
        "status": "accepted",
        "title": "One reducer is the single mutation authority"
      },
      "text": [
        {
          "insert": "Both interactive UI actions and external agent-driven edits dispatch through the same "
        },
        {
          "insert": "reduceInteractiveCanvasState",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/actions/reducer.ts",
              "symbol": "reduceInteractiveCanvasState"
            }
