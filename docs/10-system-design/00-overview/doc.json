    "b-overview-intro-2": {
      "id": "b-overview-intro-2",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "@codecaine-ai/canvas",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a FigJam-parity, typed-action, world-space interactive canvas engine, extracted from the Spectre monorepo into its own git submodule at "
        },
        {
          "insert": "packages/canvas",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". It renders a diagramming board — sticky notes, shapes, text, frames, and routed connectors — driven entirely by a single typed action vocabulary, so the same engine can be embedded interactively by a person or driven headlessly by an agent."
        }
      ],
      "children": []
    },
    "b-overview-what-heading-3": {
      "id": "b-overview-what-heading-3",
      "flavour": "heading",
      "props": {
        "level": 2
      },
      "text": [
        {
          "insert": "What this is"
        }
      ],
      "children": []
    },
    "b-overview-what-body-4": {
      "id": "b-overview-what-body-4",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The package is the engine layer only: document schema, action vocabulary and reducer, geometry helpers, pointer interaction state machine, connector routing, rendering, and FigJam-parity chrome. It is React-based but framework-agnostic about its host — it vendors its own UI primitives and has no dependency back on the Spectre app it was extracted from. See "
        },
        {
          "insert": "README.md",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "README.md"
            }
          }
        },
        {
          "insert": " for the repo layout and getting-started commands."
        }
      ],
      "children": []
    },
    "b-overview-layer-heading-5": {
      "id": "b-overview-layer-heading-5",
