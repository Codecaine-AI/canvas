      "flavour": "file-tree",
      "props": {
        "title": "Engine layer layout",
        "entries": [
          {
            "path": "packages/canvas/src/state/",
            "note": "document schema, action vocabulary, reducer, geometry helpers (pure, no DOM)"
          },
          {
            "path": "packages/canvas/src/objects/",
            "note": "the object-def registry: ObjectDef/ShapeDef, text-slot presets, outline geometry, per-kind defs"
          },
          {
            "path": "packages/canvas/src/theme/palette.ts",
            "note": "canonical 10-pick ink/fill/wash color table + per-role resolvers (leaf module)"
          },
          {
            "path": "packages/canvas/src/interaction/",
            "note": "pointer state machine, clipboard, edge-pan (pure)"
          },
          {
            "path": "packages/canvas/src/connectors/",
            "note": "elbow/orthogonal connector routing (BlockSuite-adapted A*), connection cascade"
          },
          {
            "path": "packages/canvas/src/stage/",
            "note": "SVG/DOM presentation layer: CanvasStage, ObjectShape, adaptive grid, viewport"
          },
          {
            "path": "packages/canvas/src/stage/editor/",
            "note": "React component wiring: InteractiveCanvasEditor, viewport model, hotkeys, chrome components + editor features"
          },
          {
            "path": "packages/canvas/src/stage/editor/components/ + features/",
            "note": "FigJam-parity UI chrome: CanvasDock, selection toolbar + flyouts, ColorPicker, ShapesPanel, text editing"
          },
          {
            "path": "packages/canvas/src/ui/",
            "note": "vendored UI primitives (Button/Input/Textarea/Badge/cn) — self-containment"
          },
          {
            "path": "packages/canvas/src/connectors/pathfinding/",
            "note": "MPL-2.0 BlockSuite pathfinding code; snap-distribution lives under src/stage/editor/features/snapping/; file-level copyleft boundary retained"
          },
          {
            "path": "canvases/",
            "note": "sample documents, e.g. V2 Flow FigJam sample"
          },
          {
            "path": "packages/canvas/src/index.ts",
            "note": "public barrel — the package's stable import surface"
          }
        ]
      },
