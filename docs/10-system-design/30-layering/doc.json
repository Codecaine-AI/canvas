    },
    "b-layering-predicate-body-7": {
      "id": "b-layering-predicate-body-7",
      "flavour": "paragraph",
      "children": [],
      "props": {},
      "text": [
        {
          "insert": "For any object, "
        },
        {
          "insert": "resolveSectionParent",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/section-membership.ts",
              "symbol": "resolveSectionParent"
            }
          }
        },
        {
          "insert": " chooses the smallest section that is strictly larger in area and covers at least "
        },
        {
          "insert": "SECTION_CAPTURE_OVERLAP_THRESHOLD",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/geometry.ts",
              "symbol": "SECTION_CAPTURE_OVERLAP_THRESHOLD"
            }
          }
        },
        {
          "insert": " of the object's own area. The threshold is 0.6, so exact 60% overlap qualifies and anything below it stays outside."
        }
      ]
    },
    "b-layering-parent-cache-decision-8": {
      "id": "b-layering-parent-cache-decision-8",
      "flavour": "decision",
      "children": [],
      "props": {
        "status": "accepted",
        "title": "parentId is a persisted cache"
      },
      "text": [
        {
          "insert": "Stored "
        },
        {
          "insert": "parentId",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " exists so drag capture, hidden-content filtering, validation, and persistence have a cheap membership answer. It is not an authoring surface. Geometry-mutating actions reconcile it instead of asking callers to maintain it manually."
        }
      ]
    },
    "b-layering-retention-constraint-9": {
      "id": "b-layering-retention-constraint-9",
      "flavour": "constraint",
      "children": [],
      "props": {
        "severity": "hard",
        "title": "Locked-all sections do not adopt new members"
      },
      "text": [
