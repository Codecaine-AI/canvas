    "b-layering-acyclic-observation-10": {
      "id": "b-layering-acyclic-observation-10",
      "flavour": "observation",
      "children": [],
      "props": {
        "title": "Strictly-larger sections make cycles impossible"
      },
      "text": [
        {
          "insert": "Area strictly increases on every parent hop, so the geometric resolver cannot create a cycle. The guard also prevents the pathological case where a huge frame that is 68% covered by a smaller section becomes the smaller section's child."
        }
