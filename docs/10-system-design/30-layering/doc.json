          "insert": "locked === \"all\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " retains existing members so locked content does not leak out during reconcile. The same section never adopts a new free object; the object must qualify for another unlocked section or remain parentless."
        }
