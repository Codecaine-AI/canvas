    "b-layering-mental-model-body-4": {
      "id": "b-layering-mental-model-body-4",
      "flavour": "paragraph",
      "children": [],
      "props": {},
      "text": [
        {
          "insert": "Sections stack like a layer cake. The biggest containing thing is the bottom layer; everything it contains stacks above it. Users do not push section backdrops forward or backward by hand. They move geometry, and geometry decides membership and section depth."
        }
      ]
    },
    "b-layering-derived-decision-5": {
      "id": "b-layering-derived-decision-5",
      "flavour": "decision",
      "children": [],
      "props": {
        "status": "accepted",
        "title": "Layering is derived from geometry"
      },
      "text": [
        {
          "insert": "The model treats section order as a consequence of containment, not as independent document state. If two documents have the same object geometries and section lock/visibility flags, reconcile should produce the same "
        },
        {
          "insert": "parentId",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " cache and the same paint order regardless of how the objects arrived there."
        }
      ]
    },
    "b-layering-predicate-heading-6": {
