          "insert": ") was adapted from "
        },
        {
          "insert": "BlockSuite",
          "attributes": {
            "link": "https://github.com/toeverything/blocksuite"
          }
        },
        {
          "insert": ", an open-source project licensed under the Mozilla Public License 2.0 (MPL-2.0). MPL-2.0 is "
        },
        {
          "insert": "file-level"
        },
        {
          "insert": " copyleft, not project-level: only the specific files that carry BlockSuite-derived code inherit its license obligations, not the rest of the codebase they sit alongside. To keep that boundary exact and auditable, every vendored or ported file lives under a single directory, "
        },
        {
          "insert": "packages/canvas/src/vendor/blocksuite/",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite"
            }
          }
        },
        {
          "insert": ", and each file there carries a header citing its upstream BlockSuite source path and the MPL-2.0 license, recorded in detail in "
        },
        {
          "insert": "packages/canvas/src/vendor/blocksuite/NOTICE",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/NOTICE"
            }
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
    },
