    "b-appendix-testing-p1-16": {
      "id": "b-appendix-testing-p1-16",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Tests are colocated with the code they cover rather than collected in one big suite. Each slice owns its own "
        },
        {
          "insert": "__tests__/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " subdirectory — "
        },
        {
          "insert": "state/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "objects/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "interaction/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "connectors/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", "
        },
        {
          "insert": "stage/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and each vertical feature slice under "
        },
        {
          "insert": "stage/editor/features/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (selection, move, place, snapping, selection-toolbar, context-menu, text-editing, section-fit) — plus a small top-level "
        },
        {
          "insert": "src/__tests__/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for cross-cutting suites, notably "
        },
        {
          "insert": "import-boundaries.test.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/__tests__/import-boundaries.test.ts"
            }
          }
        },
        {
          "insert": ", which encodes the layer order of the current tree. Run the full package suite with "
        },
        {
          "insert": "bun test packages/canvas/src",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " from the repo root, or scope to a single slice's "
        },
        {
          "insert": "__tests__/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " directory when iterating on one part of the engine. Bun runs those tests on "
        },
        {
          "insert": "happy-dom",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " via "
        },
        {
          "insert": "bunfig.toml",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "bunfig.toml"
            }
          }
        },
        {
          "insert": " preloading "
        },
        {
          "insert": "happydom.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "happydom.ts"
            }
          }
        },
        {
          "insert": " (which registers "
        },
        {
          "insert": "@happy-dom/global-registrator",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "); the same Bun config sets "
        },
        {
          "insert": "root = \"packages\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " so the docs-framework submodule's vendored tests stay out of "
        },
        {
          "insert": "bun test",
