        },
        {
          "insert": " math primitives the other files need. A sixth file, "
        },
        {
          "insert": "connection-overlay.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/routing/connection-overlay.ts"
