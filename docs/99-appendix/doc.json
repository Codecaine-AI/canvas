    "b-appendix-vendor-constraint-7": {
      "id": "b-appendix-vendor-constraint-7",
      "flavour": "constraint",
      "props": {
        "severity": "hard",
        "title": "MPL-2.0 file-level boundary"
      },
      "text": [
        {
          "insert": "Do not move BlockSuite-derived logic out of "
        },
        {
          "insert": "src/vendor/blocksuite/",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite"
            }
          }
        },
        {
          "insert": " into non-vendor files without legal review, and do not add non-BlockSuite-derived code into "
        },
        {
          "insert": "vendor/blocksuite/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The directory boundary is the license boundary — keep it exact. If a vendored file is ever modified, update "
        },
        {
          "insert": "NOTICE",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/vendor/blocksuite/NOTICE"
            }
          }
        },
        {
          "insert": " and the file's own header accordingly, per the record's own instructions."
        }
      ],
      "children": []
    },
