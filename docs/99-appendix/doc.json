        },
        {
          "insert": "path-generator.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "snap-distribution.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " are explicitly-labeled extractions that pull only the pure, framework-free algorithm logic out of larger BlockSuite modules (dropping Lit, signals, and canvas-paint/overlay code); and "
        },
        {
          "insert": "gfx-types.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a dependency-free reimplementation of the handful of "
        },
        {
          "insert": "@blocksuite/global",
          "attributes": {
            "code": true
