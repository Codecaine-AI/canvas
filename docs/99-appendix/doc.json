          }
        },
        {
          "insert": ", an open-source project licensed under the Mozilla Public License 2.0 (MPL-2.0). MPL-2.0 is "
        },
        {
          "insert": "file-level"
        },
        {
          "insert": " copyleft, not project-level: only the specific files that carry BlockSuite-derived code inherit its license obligations, not the rest of the codebase they sit alongside. The former single vendor directory ("
