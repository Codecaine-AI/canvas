        },
        {
          "insert": ") was dissolved in the layout overhaul: the pathfinding files now live in "
        },
        {
          "insert": "packages/canvas/src/connectors/pathfinding/",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/pathfinding"
            }
          }
        },
        {
          "insert": ", while "
        },
        {
