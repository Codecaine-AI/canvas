    "b-appendix-vendor-constraint-7": {
      "id": "b-appendix-vendor-constraint-7",
      "flavour": "constraint",
      "props": {
        "severity": "hard",
        "title": "MPL-2.0 file-level boundary"
      },
      "text": [
        {
          "insert": "The MPL-2.0 boundary is per-file: every BlockSuite-derived file carries an MPL-2.0 provenance header, and "
        },
        {
          "insert": "PROVENANCE.md",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "PROVENANCE.md"
            }
          }
        },
        {
          "insert": "'s BlockSuite MPL provenance section enumerates the exact set. Do not blend BlockSuite-derived logic into other files without legal review, do not add unrelated code into the listed files, and do not strip their headers. The header-plus-record set is the license boundary — keep it exact. If a ported file is ever modified, update "
        },
        {
          "insert": "PROVENANCE.md",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and the file's own header accordingly, per the record's own instructions."
        }
      ],
      "children": []
    },
