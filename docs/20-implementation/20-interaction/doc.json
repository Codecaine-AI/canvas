    "b-interaction-clipboard-body-20": {
      "id": "b-interaction-clipboard-body-20",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "clipboard.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/clipboard.ts",
              "label": "clipboard.ts"
            }
          }
        },
        {
          "insert": " implements an in-memory clipboard — a module-level "
        },
        {
          "insert": "clipboardMemory",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " variable, not the OS clipboard. "
        },
        {
          "insert": "copySelection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/clipboard.ts",
              "label": "copySelection",
              "symbol": "copySelection"
            }
          }
        },
        {
          "insert": " captures the current object selection plus every descendant (via "
        },
        {
          "insert": "collectDescendantIds",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", so copying a section brings its children along), plus every connection whose both endpoints land inside the captured set, deep-cloned via "
        },
        {
          "insert": "structuredClone",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and records a "
        },
        {
          "insert": "sourcePoint",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (the copied selection's bounds center) used later to compute the paste offset. The editor's hotkey handler ("
        },
        {
          "insert": "use-canvas-hotkeys.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/editor/use-canvas-hotkeys.ts",
              "label": "use-canvas-hotkeys.ts"
            }
          }
        },
        {
          "insert": ") stores the result in the module singleton via "
        },
        {
          "insert": "setClipboardMemory",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/clipboard.ts",
              "label": "setClipboardMemory",
              "symbol": "setClipboardMemory"
            }
          }
        },
        {
          "insert": " on Cmd/Ctrl-C. On paste, it reads the payload back with "
        },
        {
          "insert": "getClipboardMemory",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/clipboard.ts",
              "label": "getClipboardMemory",
              "symbol": "getClipboardMemory"
            }
          }
        },
        {
          "insert": " and calls "
        },
        {
          "insert": "buildPastePayload",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/clipboard.ts",
              "label": "buildPastePayload",
              "symbol": "buildPastePayload"
            }
          }
        },
        {
          "insert": ", which re-clones the objects and connections and translates every geometry — and every explicit connection waypoint, because waypoints are stored as absolute world coordinates, so paste offsets translate them explicitly — by the delta between a target drop point (or a default 24-unit offset when pasting without one) and the recorded "
        },
        {
          "insert": "sourcePoint",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", so a fan of connectors pastes intact rather than re-routing from scratch. The resulting objects and connections are dispatched in a single "
        },
        {
          "insert": "canvas.addObjects",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/actions/objects.ts",
              "label": "canvas.addObjects",
              "symbol": "canvas.addObjects"
            }
          }
        },
        {
          "insert": " action, so the whole paste — however many objects and connections it contains — lands as one reducer call and one undo step."
        }
      ],
      "children": []
