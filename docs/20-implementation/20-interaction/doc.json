      "text": [
        {
          "insert": "createFrameCoalescer",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/frame-coalescer.ts",
              "label": "createFrameCoalescer",
              "symbol": "createFrameCoalescer"
            }
          }
        },
        {
          "insert": " is the kernel rAF coalescer: callers provide a commit function and may inject the tiny request/cancel scheduler shape, so tests can drive frames deterministically with a fake scheduler. Its contract is "
        },
        {
          "insert": "push",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (record latest value and schedule one frame if needed), "
        },
        {
          "insert": "flush",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (cancel the pending frame and synchronously commit the queued value), "
        },
        {
          "insert": "cancel",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (drop the pending value without committing), and "
        },
        {
          "insert": "isPending",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (whether a frame is scheduled). The editor pipeline batches pointer-move work through it; see "
        },
        {
          "insert": "20-implementation/50-editor",
