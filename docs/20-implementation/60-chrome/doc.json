    "b-chrome-para-context-toolbar-20": {
      "id": "b-chrome-para-context-toolbar-20",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "ContextToolbar",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/chrome/ContextToolbar.tsx",
              "symbol": "ContextToolbar"
            }
          }
        },
        {
          "insert": "'s "
        },
        {
          "insert": "variant",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " prop must be derived by the consumer from the current selection: a single shape object maps to "
        },
        {
          "insert": "\"shape\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", a section type to "
        },
        {
          "insert": "\"section\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", a connection to "
        },
        {
          "insert": "\"connector\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", active text-edit (shape label, sticky body, or connector label) to "
        },
        {
          "insert": "\"text\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and a sticky to "
        },
        {
          "insert": "\"sticky\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The toolbar is positioned via "
        },
        {
          "insert": "positionContextToolbar(selectionRect, { width: measuredWidth, height: 29 }, viewportSize)",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/chrome/context-toolbar-position.ts",
              "symbol": "positionContextToolbar"
            }
          }
        },
        {
          "insert": " — because the pill's real width depends on which variant (and therefore how many controls) is rendered, a consumer should measure the rendered pill via a ref and "
        },
        {
          "insert": "getBoundingClientRect()",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " rather than hardcode a width. "
        },
        {
          "insert": "onAction(actionId, value?)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is a single callback for the whole toolbar; flyout controls (marked "
        },
        {
          "insert": "hasFlyout: true",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " in the registry) currently only toggle local "
        },
        {
          "insert": "aria-expanded",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " state and do not render flyout contents themselves — a consumer renders the appropriate flyout (reusing "
        },
        {
          "insert": "ColorPalettePopover",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for any "
        },
        {
          "insert": "\"color\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "\"tint\"",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " action) anchored below the clicked control. The connector's \"T\" add-text-label control is exported separately as "
        },
        {
          "insert": "CONNECTOR_ADD_LABEL_ICON",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/chrome/ContextToolbar.tsx",
              "symbol": "CONNECTOR_ADD_LABEL_ICON"
            }
          }
        },
        {
          "insert": ", since the connector's default 6-control set ("
        },
        {
          "insert": "color/stroke/dash/routing/arrowhead/label-align",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ") already reaches the catalog's measured count of 6 without it."
