        "format": "mdx",
        "type": "overview",
        "concepts": [
          "CanvasStage",
          "adaptive grid",
          "screen-pixel band",
          "FigJam tokens",
          "code tokenizer"
        ]
      },
      "children": [
        "b-render-title-1",
        "b-render-intro-2",
        "b-render-heading-canvasstage-3",
        "b-render-canvasstage-body-4",
        "b-render-canvasstage-helpers-5",
        "b-render-canvasstage-imports-6",
        "b-render-heading-grid-7",
        "b-render-grid-mechanism-8",
