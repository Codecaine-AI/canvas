    "b-studio-embed-ux": {
      "id": "b-studio-embed-ux",
      "flavour": "decision",
      "props": {
        "status": "accepted",
        "title": "Keep inline previews static; expand to navigate; edit separately"
      },
      "text": [
        {
          "insert": "An inline canvas card should show the section crop without capturing drag or wheel input. An explicit full-screen action promotes it to the interactive read-only viewer, where pan and zoom are expected. Authoring is a third context: an Edit in Canvas Studio action opens the editor separately so the reader does not lose the surrounding document or webpage state. This progression is a portable host contract, not docs-system-only behavior."
        }
      ],
      "children": []
