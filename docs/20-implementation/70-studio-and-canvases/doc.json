    "b-studio-app-para-7": {
      "id": "b-studio-app-para-7",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The backend is the shared Node handler in "
        },
        {
          "insert": "server/canvas-file-api.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/studio/server/canvas-file-api.ts",
              "symbol": "createCanvasFileApiHandler"
            }
          }
        },
        {
          "insert": ". Vite and Electron both mount it, so documents and previews behave the same in the web and desktop shells. Documents at rest are "
        },
        {
          "insert": "canvases/*.canvas.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " files at the repo root; ids must match "
        },
        {
          "insert": "CANVAS_ID_PATTERN",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and resolve to "
        },
        {
          "insert": "${id}.canvas.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " under that directory. "
        },
        {
          "insert": "GET /api/canvases",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " reads the directory, filters "
        },
        {
          "insert": "*.canvas.json",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", returns "
        },
        {
          "insert": "{id, title, updated_at}",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with "
        },
        {
          "insert": "updated_at",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " from mtime, and sorts newest first; "
        },
        {
          "insert": "GET /api/canvases/:id",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " streams the file without validating it on read. "
        },
        {
          "insert": "POST",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " returns 409 if the file exists, and both "
        },
        {
          "insert": "POST",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " and "
        },
        {
          "insert": "PUT",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " validate through "
        },
        {
          "insert": "validateInteractiveCanvasDocument",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/schema/validate.ts",
              "symbol": "validateInteractiveCanvasDocument"
            }
          }
        },
        {
          "insert": "; invalid documents get 422 with issues, valid documents are written as pretty-printed JSON, and "
        },
        {
          "insert": "DELETE",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " unlinks the file. On the client side, "
        },
        {
          "insert": "App.tsx",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/studio/src/App.tsx"
            }
          }
        },
        {
          "insert": " queues a save on every "
        },
        {
          "insert": "onDocumentChange",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", skips writes unchanged from the loaded snapshot, debounces 800ms into a "
        },
        {
          "insert": "PUT",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", and flushes on "
        },
        {
          "insert": "popstate",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", Back, and "
        },
        {
          "insert": "beforeunload",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with "
        },
        {
          "insert": "keepalive",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". The editor trim shows Saved or Save failed — retry. Opening a board deep-clones the fetched document ("
        },
        {
          "insert": "JSON.parse(JSON.stringify(...))",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), snapshots it for the dirty check, and maps an unknown id to the not-found state."
        }
      ],
