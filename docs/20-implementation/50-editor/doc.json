          "attributes": {
            "code": true
          }
        },
        {
          "insert": " / "
        },
        {
          "insert": "MAX_ZOOM = 4",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), "
        },
        {
          "insert": "zoomAtPoint",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (zoom while keeping a given screen point fixed in world space), "
