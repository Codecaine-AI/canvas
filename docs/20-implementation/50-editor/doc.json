        {
          "insert": "{ x, y, zoom }",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", where "
        },
        {
          "insert": "(x, y)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is the world point shown at screen origin "
        },
        {
          "insert": "(0, 0)",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ". It exports "
        },
        {
          "insert": "worldToScreen",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "screenToWorld",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " conversions, "
        },
        {
          "insert": "clampZoom",
          "attributes": {
            "code": true
