          "insert": "keyup",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " listeners for space state, and pointer capture for the drag itself), or via plain left-drag when the hook is constructed with "
        },
        {
          "insert": "panOnPlainDrag: true",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (the editor's \"hand\" tool). This hook — not "
        },
        {
          "insert": "useCanvasHotkeys",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — is the sole owner of space-drag panning."
        }
      ],
      "children": []
    },
