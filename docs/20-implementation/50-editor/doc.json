        {
          "insert": " is the pure viewport/camera model — no React, no side effects, just coordinate math over a "
        },
        {
          "insert": "ViewportState",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/viewport.ts",
              "symbol": "ViewportState"
