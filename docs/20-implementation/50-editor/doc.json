    "b-editor-intro-1": {
      "id": "b-editor-intro-1",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The editor layer is where the interactive canvas engine becomes an actual interactive editor: it composes the pure render layer, the interaction state machine, viewport/camera control, and keyboard shortcuts into a single component tree, and dispatches every user gesture as a typed "
        },
        {
          "insert": "CanvasAction",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/actions/types.ts",
              "symbol": "CanvasAction"
            }
          }
        },
        {
          "insert": " through the model's reducer. This doc covers the four files that make up that layer — the editor entrypoint, the read-only viewer, the viewport math, and the hotkey binding table."
        }
      ],
      "children": []
    },
