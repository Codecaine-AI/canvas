    "b-editor-use-canvas-viewport-wheel-11": {
      "id": "b-editor-use-canvas-viewport-wheel-11",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Wheel handling distinguishes plain scroll (pan) from ctrl/meta-modified scroll (zoom toward the cursor — trackpad pinch also arrives as a "
        },
        {
          "insert": "ctrlKey",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " wheel event in browsers). Rapid wheel events are coalesced via "
        },
        {
          "insert": "createFrameCoalescer",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/interaction/frame-coalescer.ts",
              "symbol": "createFrameCoalescer"
            }
          }
        },
        {
          "insert": " into at most one viewport commit per animation frame: each event accumulates into a pending pan-delta/zoom-factor frame, and the coalescer applies the accumulated frame using the latest cursor point, so the point under the cursor stays exactly fixed even when several wheel deltas were merged."
        }
      ],
      "children": []
    },
