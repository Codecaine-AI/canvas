    "b-editor-text-editing-para": {
      "id": "b-editor-text-editing-para",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Text editing is the "
        },
        {
          "insert": "stage/editor/features/text-editing/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " feature (renamed from the old label-editing feature when the schema collapsed to one "
        },
        {
          "insert": "text",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " field). "
        },
        {
          "insert": "useTextEditing",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/editor/features/text-editing/use-text-editing.ts",
              "symbol": "useTextEditing"
            }
          }
        },
        {
          "insert": " owns two editor states: the in-place OBJECT text editor (opened by double-click for any def whose "
        },
        {
          "insert": "textEditing.editable",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " is true — pure glyphs like plus/or-junction/summing-junction refuse it) and the connector-label editor (an input at "
        },
        {
          "insert": "routeConnection().labelPoint",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", per the ConnectorDef's routed-midpoint contract). The object editor is in-place by construction (D14): "
        },
        {
          "insert": "TextEditingOverlay",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/editor/features/text-editing/TextEditingOverlay.tsx",
              "symbol": "TextEditingOverlay"
            }
          }
        },
        {
          "insert": " positions and styles its textarea from the SAME "
        },
        {
          "insert": "resolveTextSlot",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/objects/text-slots.ts",
              "symbol": "resolveTextSlot"
            }
          }
        },
        {
          "insert": " descriptor the at-rest renderer uses — same rect, same typography, chip counter-scale included — while the def's renderer receives "
        },
        {
          "insert": "hideText",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " so at rest and mid-edit are pixel-identical, caret aside."
        },
        {
          "insert": " All four editing surfaces also set an explicit inline "
        },
        {
          "insert": "user-select: text",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ": the stage root disables text selection wholesale (see the render-layer decision — board text is chrome, drags must never sweep a native selection across labels), and the active editor is the one place selection is re-enabled."
        }
      ],
      "children": []
    },
