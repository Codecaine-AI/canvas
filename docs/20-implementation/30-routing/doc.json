        }
      ],
      "children": []
    },
    "b-routing-anchor-p2-9": {
      "id": "b-routing-anchor-p2-9",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The routing module also exposes two lower-level anchor helpers used elsewhere in the engine: "
        },
        {
          "insert": "anchorPoints",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "anchorPoints"
            }
          }
        },
        {
          "insert": " returns all four side-midpoints of a bounds, and "
        },
        {
          "insert": "nearestAnchor",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "nearestAnchor"
            }
          }
        },
        {
          "insert": " picks whichever of those four is closest to an arbitrary point — a plain bounding-box heuristic, distinct from the real-outline anchor projection objects/geometry.ts performs for live drag/hover interaction (see below)."
        }
      ],
      "children": []
    },
    "b-routing-heading-waypoint-10": {
