    "b-routing-anchor-p1-8": {
      "id": "b-routing-anchor-p1-8",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Before any path is computed, "
        },
        {
          "insert": "routeConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeConnection"
            }
          }
        },
        {
          "insert": " decides which side of each endpoint object the connection attaches to. "
        },
        {
          "insert": "autoPickAnchors",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "autoPickAnchors"
            }
          }
        },
        {
          "insert": " now prefers genuinely facing sides before falling back to center-delta dominance: if the objects' vertical spans overlap within the 8px auto-route alignment tolerance, it chooses right/left or left/right; if their horizontal spans overlap, it chooses bottom/top or top/bottom; otherwise the dominant center separation wins, with horizontal ties going horizontal. This picked pair is only the fallback: an explicit "
        },
        {
          "insert": "connection.from.anchor",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "connection.to.anchor",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " override (validated by "
        },
        {
          "insert": "explicitAnchor",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "explicitAnchor"
            }
          }
        },
        {
          "insert": " against the four "
        },
        {
          "insert": "top",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "right",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "bottom",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "left",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " values) wins when set, and an explicit relative "
        },
        {
          "insert": "position",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " (a "
        },
        {
          "insert": "[rx, ry]",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " fraction of an object's bounds, resolved by "
        },
        {
          "insert": "pointForPosition",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "pointForPosition"
            }
          }
        },
        {
