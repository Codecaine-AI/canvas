    "b-routing-intro-2": {
      "id": "b-routing-intro-2",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "A connection's visual path is never stored as a fixed drawing — it is computed from the current geometry of its two endpoint objects every time either side moves. "
        },
        {
          "insert": "routeConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeConnection"
            }
          }
        },
        {
          "insert": " in "
        },
        {
          "insert": "packages/canvas/src/connectors/routing.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts"
            }
          }
        },
        {
          "insert": " is the single object-to-object routing entry point: given a from-object, a to-object, and a connection's anchor/position/waypoint overrides, it returns a "
        },
        {
          "insert": "RoutedConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "RoutedConnection"
            }
          }
        },
        {
          "insert": " — an SVG path string, the true start/end anchor points, a label placement point, and the route's world-space vertex list. The router is style-agnostic: solid and dashed connectors share the same route, and there are no straight/smooth branches here. Its branches are explicit orthogonal "
        },
        {
          "insert": "waypoints",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", near-straight exact anchoring, simple elbow routing, and an obstacle-triggered orthogonal A* fallback."
        }
      ],
      "children": []
    },
    "b-routing-heading-elbow-3": {
      "id": "b-routing-heading-elbow-3",
