    "b-routing-elbow-p3-6": {
      "id": "b-routing-elbow-p3-6",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "Whichever branch produces the route, waypoints are deduplicated ("
        },
        {
          "insert": "dedupeConsecutivePoints",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "dedupeConsecutivePoints"
            }
          }
        },
        {
          "insert": ") and turned into a rendered SVG path by "
        },
        {
          "insert": "roundedPolylinePath",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "roundedPolylinePath"
            }
          }
        },
        {
          "insert": ", which rounds interior corners (clamped to half the shorter adjacent segment's length, so short segments still get a sane smaller radius rather than overshooting) and pulls the first/last rendered points back by a fixed end-gap along their own tangent so the drawn stroke never touches the target border — the connection's "
        },
        {
          "insert": "start",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "end",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " fields still carry the true, untouched anchor points for endpoint-drag handles and label placement."
        }
      ],
      "children": []
    },
