      "children": []
    },
    "b-routing-elbow-p1-4": {
      "id": "b-routing-elbow-p1-4",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "routeConnection",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeConnection"
            }
          }
        },
        {
          "insert": " first resolves bounds, anchors, explicit side overrides, and explicit relative "
        },
        {
          "insert": "position",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " overrides. If stored "
        },
        {
          "insert": "connection.waypoints",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " exist and form an orthogonal polyline, "
        },
        {
          "insert": "routeWaypoints",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeWaypoints"
            }
          }
        },
        {
          "insert": " uses them. Otherwise the router tries an exact straight route when facing anchors are already aligned, then builds a simple "
        },
        {
          "insert": "routeElbow",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeElbow"
            }
          }
        },
        {
          "insert": " path. Only when that simple elbow crosses an extra obstacle does it call "
        },
        {
          "insert": "routeOrthogonalAStar",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/routing.ts",
              "symbol": "routeOrthogonalAStar"
            }
          }
        },
        {
          "insert": ", which delegates pathfinding to "
        },
        {
          "insert": "PathGenerator.generateOrthogonalConnectorPath",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/pathfinding/path-generator.ts",
              "symbol": "PathGenerator"
            }
          }
        },
        {
          "insert": " — an A* pathfinder adapted from BlockSuite (an MPL-2.0 licensed open-source project). If A* throws, returns fewer than two usable points, or otherwise yields no route, the caller returns the already-computed simple elbow."
        }
      ],
      "children": []
    },
