    "b-theme-palette-decision-7": {
      "id": "b-theme-palette-decision-7",
      "flavour": "decision",
      "props": {
        "status": "accepted",
        "title": "Every hex is provenance-annotated, sampled or derived"
      },
      "text": [
        {
          "insert": "Each of the table's cells carries an inline comment tagging it as sampled (citing its FigJam source table or spec section in board-design-reference/analysis/) or derived (no FigJam sample exists; synthesized in the same pastel band and flagged at the cell). Teal is the honest example: its fill was lightened from the sampled #5AD8CC to #C6FAF6 to sit with its pastel siblings, and its wash #EAFDFB is derived outright. New picks or cell changes must keep this discipline — the annotation IS the review trail."
        }
      ],
      "children": []
    },
