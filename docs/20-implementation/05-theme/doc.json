          "insert": "figjam-tokens.ts",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " constants module mirroring every pixel-sampled FigJam measurement. The theme dispersal inverted that: constants now sit beside the renderer that consumes them — grid constants in "
        },
        {
          "insert": "grid.ts",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/grid.ts"
            }
          }
        },
        {
          "insert": ", object chrome metrics with the object defs, connector stroke/dash/chip metrics in the connector slice, arrowhead ratios in "
        },
        {
          "insert": "CanvasStage.tsx",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/CanvasStage.tsx"
            }
          }
        },
        {
          "insert": " — and "
        },
        {
          "insert": "theme/",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " keeps only what is genuinely global and shared. The provenance discipline survived the dispersal intact: each dispersed constant remains a hand-written, typed mirror of board-design-reference/analysis measurements, annotated at its new site."
        }
      ],
      "children": []
