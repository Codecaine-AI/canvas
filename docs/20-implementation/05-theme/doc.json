              "path": "packages/canvas/src/theme/palette.ts",
              "symbol": "CANVAS_PALETTE"
            }
          }
        },
        {
          "insert": " is the canonical swatch table: one row per pick in the closed 10-color roster, each row a "
        },
        {
          "insert": "Swatch",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/theme/palette.ts",
              "symbol": "Swatch"
            }
          }
        },
        {
          "insert": " carrying every expression a pick can have — the picker-preview hex, the shape fill/border pair, the section tint + title-chip pair, the exact sticky fill, and the connector stroke. Documents store swatch IDS ("
