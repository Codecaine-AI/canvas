          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/theme/tokens.ts"
            }
          }
        },
        {
          "insert": " owns the non-color remainder — canvas surface variables, the universal shape stroke, the text size hierarchy. Theme depends on nothing but "
