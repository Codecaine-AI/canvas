          "insert": "connection.label",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " renders a rounded chip centered at the routed label point, which is the route's arc-length midpoint. The chip uses a canvas-colored backing ("
        },
        {
          "insert": "#F5F5F5",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "), "
