    "b-render-canvasstage-body-4": {
      "id": "b-render-canvasstage-body-4",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "CanvasStage",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/CanvasStage.tsx",
              "symbol": "CanvasStage"
            }
          }
        },
        {
          "insert": " is the top-level exported component, now about 600 lines and delegated into sibling render modules. It takes the document, viewport, selection and interaction state, and slot props ("
        },
        {
          "insert": "overlay",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for screen-space UI, "
        },
        {
          "insert": "worldOverlay",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for world-space editor additions such as the inline connector-label input) and renders the scene. It applies the camera transform — translate by "
        },
        {
          "insert": "-viewport.x * zoom, -viewport.y * zoom",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " then scale by "
        },
        {
          "insert": "zoom",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " — to a single world layer, and projects world coordinates to screen coordinates via "
        },
        {
          "insert": "worldToScreen",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " for screen-space overlays including the drag-select rect, snap and distribution guides, spacing chips, selection handles, anchor dots, and connector drag previews. Hover quick-connect previews are assembled in "
        },
        {
          "insert": "CanvasStage",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/stage/CanvasStage.tsx",
              "symbol": "CanvasStage"
            }
          }
        },
        {
          "insert": " and rendered through "
        },
        {
          "insert": "ConnectorDragPreview",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/connectors/ConnectorDragPreview.tsx",
              "symbol": "ConnectorDragPreview"
            }
          }
        },
        {
          "insert": "."
        }
      ],
      "children": []
