    "b-render-intro-2": {
      "id": "b-render-intro-2",
      "flavour": "paragraph",
      "props": {},
      "text": [
        {
          "insert": "The render layer is the presentation side of the canvas engine: given an "
        },
        {
          "insert": "InteractiveCanvasDocument",
          "attributes": {
            "reference": {
              "kind": "source",
              "path": "packages/canvas/src/state/schema/document.ts",
              "symbol": "InteractiveCanvasDocument"
            },
            "code": true
          }
        },
        {
          "insert": " and a viewport, it draws objects, connections, sections, and annotations to the screen as a world-space DOM/SVG tree. It owns no editing state of its own — it is the shared renderer both the read-only viewer and the interactive editor mount, driven entirely by props."
        }
      ],
      "children": []
    },
    "b-render-heading-canvasstage-3": {
      "id": "b-render-heading-canvasstage-3",
