        },
        {
          "insert": " (0.4), scale by "
        },
        {
          "insert": "1 / zoom",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": ", use horizontal/vertical resize cursors by segment axis, and are emitted as "
        },
        {
          "insert": "data-canvas-bend-segment",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " rects. Bend segments include straight single-segment connectors too; when a label is present, segment generation reserves clearance around the label so pills sit away from the chip rather than covering it."
        }
      ],
      "children": []
    },
