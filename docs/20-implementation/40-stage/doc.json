        {
          "insert": " keeps the visible path stroke resolved from the connector palette color, so selection never recolors the line to primary blue. Selection adds hollow endpoint circles at the routed start/end and blue bend-segment pills. The pills render for selected connectors only when zoom is at least "
        },
        {
          "insert": "BEND_HANDLES_MIN_ZOOM",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
