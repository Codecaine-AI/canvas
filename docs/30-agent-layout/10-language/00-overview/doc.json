              "label": "row and col — weighted splits"
            }
          }
        },
        {
          "insert": " has one child per weight; a "
        },
        {
          "insert": "grid",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "doc",
              "path": "30-agent-layout/10-language/50-grid",
              "label": "grid — a repeated-cell lattice"
