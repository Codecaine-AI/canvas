    "b-language-alignfacts-body-10": {
      "id": "b-language-alignfacts-body-10",
      "flavour": "paragraph",
      "children": [],
      "props": {},
      "text": [
        {
          "insert": "After the tree, at the left margin, in this order: all "
        },
        {
          "insert": "align",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "doc",
              "path": "30-agent-layout/10-language/70-align",
