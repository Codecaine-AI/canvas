    "b-language-intro-2": {
      "id": "b-language-intro-2",
      "flavour": "paragraph",
      "children": [],
      "props": {},
      "text": [
        {
          "insert": "The layout language is a derived, disposable view of a canvas document. The fitter writes it with "
        },
        {
          "insert": "serializeSketch",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas-agent/src/pipeline/serialize.ts",
              "symbol": "serializeSketch"
            }
          }
        },
        {
          "insert": ", the AI edits it, "
        },
        {
          "insert": "parseSketch",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas-agent/src/pipeline/serialize.ts",
              "symbol": "parseSketch"
            }
          }
        },
        {
          "insert": " reads the edited text back into a "
        },
        {
          "insert": "Sketch",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas-agent/src/pipeline/types.ts",
              "symbol": "Sketch"
            }
          }
        },
        {
          "insert": ", and the solver expands it back into geometry through "
        },
        {
          "insert": "expandSketch",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas-agent/src/pipeline/expand.ts",
              "symbol": "expandSketch"
            }
          }
        },
        {
          "insert": ". Read a program in three passes: the indented tree first, then the alignment facts, then the arrows."
        }
      ]
    },
    "b-language-clarity-decision-3": {
      "id": "b-language-clarity-decision-3",
      "flavour": "decision",
      "children": [],
      "props": {
        "status": "accepted",
        "title": "Clarity over compression"
      },
      "text": [
        {
          "insert": "Every value is labeled, every reference is a declared number, and indentation is the only nesting syntax. The canvas document is the single source of truth; the program is fitted fresh per edit and discarded after solving, so the grammar spends its budget on readability, not brevity."
        }
      ]
    },
