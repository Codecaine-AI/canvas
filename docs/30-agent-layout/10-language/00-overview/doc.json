              "path": "30-agent-layout/10-language/20-section",
              "label": "section — a real container object"
            }
          }
        },
        {
          "insert": ") declares a positive integer, assigned in declaration order starting at 1. All later references — "
        },
        {
          "insert": "align",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "doc",
              "path": "30-agent-layout/10-language/70-align",
              "label": "align — a shared centerline"
