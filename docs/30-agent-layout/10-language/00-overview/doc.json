        "title": "The nine statements",
        "columns": [
          "statement",
          "meaning"
        ],
        "rows": [
          [
            "item",
            "a real object — one per line, every field labeled"
          ],
          [
            "section",
            "a real container with a label — exactly one child"
          ],
          [
            "group",
            "wraps two or more loose items that share one slot"
          ],
          [
            "row",
            "split a region into side-by-side bands, one child per weight"
          ],
          [
            "col",
            "split a region into stacked bands, one child per weight"
          ],
          [
            "grid",
            "rows × columns of identical cells, one item line per cell"
          ],
          [
            "align",
            "put objects on one shared centerline — written after the tree"
          ],
          [
            "fan",
            "a hub with children spread out beside it — written after the tree"
          ],
          [
            "arrows",
            "the block of connections — always last, even when empty"
          ]
        ]
      }
