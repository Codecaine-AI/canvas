      "text": [
        {
          "insert": "A real object on the board — one per line, every field labeled. An item says what it is and where it sits by compass, never by pixel coordinates; the solver turns that into geometry. Fields, in fixed order:"
        }
      ]
    },
    "b-item-table-3": {
      "id": "b-item-table-3",
      "flavour": "structured-table",
      "children": [],
      "props": {
        "title": "item fields",
        "columns": [
          "field",
          "required",
          "values"
        ],
        "rows": [
          [
            "number",
            "yes",
            "positive integer, unique — declared once, reused by align, fan, and arrows"
          ],
          [
            "text=",
            "yes",
            "the object's name; duplicates legal; JSON-quoted when not [A-Za-z0-9][A-Za-z0-9_.:-]*"
          ],
          [
            "type=",
            "yes",
            "any canvas shape type (process, sticky, decision, database, pill, ...)"
          ],
          [
            "size=",
            "yes",
            "S, M, L (0.72× / 1× / 1.35× of the type's base size)"
          ],
          [
            "at=",
            "see below",
            "compass: N NE E SE S SW W NW C"
          ],
          [
            "hug=",
            "optional",
            "compass corner; only on direct children of a split"
          ]
        ]
      }
    },
