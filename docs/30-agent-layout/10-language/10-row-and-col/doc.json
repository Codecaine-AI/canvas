    "b-rowcol-body-2": {
      "id": "b-rowcol-body-2",
      "flavour": "paragraph",
      "children": [],
      "props": {},
      "text": [
        {
          "insert": "Weights are "
        },
        {
          "insert": "|",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "-separated numbers; the space divides proportionally along the axis ("
        },
        {
          "insert": "row",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " = left→right, "
        },
        {
          "insert": "col",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " = top→bottom). Weights are proportions, never pixels: "
        },
        {
          "insert": "row 1|2",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " means the second band is twice as wide. Exactly one indented child per weight, in order. A bare "
        },
        {
          "insert": "row",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": "/"
        },
        {
          "insert": "col",
          "attributes": {
            "code": true
          }
        },
        {
          "insert": " with no weights has no children. An empty corridor is kept between neighboring bands automatically, so connector lines have room to run."
        }
      ]
    },
