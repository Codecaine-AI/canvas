    "b-overview-fact-view-15": {
      "id": "b-overview-fact-view-15",
      "flavour": "list-item",
      "children": [],
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "The program is a view, not a file.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " The language is derived fresh from the document on every edit and thrown away after. It can never go stale."
        }
      ]
    },
    "b-overview-fact-intent-16": {
      "id": "b-overview-fact-intent-16",
      "flavour": "list-item",
      "children": [],
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Intent lives inside the document.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " Grids, lanes, shared centerlines, and fans are saved next to the geometry in the same file, so they cannot drift apart."
        }
      ]
    },
    "b-overview-fact-hands-17": {
      "id": "b-overview-fact-hands-17",
      "flavour": "list-item",
      "children": [],
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Your hands stay on the canvas.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " Dragging a box edits geometry directly. A reconcile pass then checks whether the stored intents still hold."
        }
      ]
    },
    "b-overview-fact-ownership-18": {
      "id": "b-overview-fact-ownership-18",
      "flavour": "list-item",
      "children": [],
      "props": {
        "ordered": false
      },
      "text": [
        {
          "insert": "Who owns what.",
          "attributes": {
            "bold": true
          }
        },
        {
          "insert": " The AI owns structure and intent. The solver owns every pixel. The router owns every line. You own anything, any time."
        }
      ]
    },
