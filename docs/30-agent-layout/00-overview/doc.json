        {
          "insert": "routeSketchEdges",
          "attributes": {
            "code": true,
            "reference": {
              "kind": "source",
              "path": "packages/canvas-agent/src/pipeline/route.ts",
              "symbol": "routeSketchEdges"
            }
          }
        },
        {
          "insert": " (geometry to connector paths). Everything except the model call is a pure function."
        }
      ]
