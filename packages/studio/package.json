{
  "name": "@codecaine-ai/studio",
  "productName": "Canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "vite build",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/main.cjs",
    "studio": "bun run build && bun run build:electron && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codecaine-ai/canvas": "workspace:*",
    "@codecaine-ai/canvas-agent": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "latest",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^43.1.0",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.0"
  }
}
