{
  "name": "codecaine-canvas",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": ["packages/*", "apps/*"],
  "trustedDependencies": ["electron", "esbuild"],
  "scripts": {
    "docs": "bun tools/docs-framework/packages/docs-cli/src/index.ts",
    "test": "bun test packages/canvas/src",
    "typecheck": "bun run typecheck:canvas && bun run typecheck:studio && bun run typecheck:canvas-agent",
    "typecheck:canvas": "bunx --bun tsc -p packages/canvas/tsconfig.json --noEmit",
    "typecheck:studio": "bunx --bun tsc -p packages/studio/tsconfig.json --noEmit",
    "typecheck:canvas-agent": "bunx --bun tsc -p packages/canvas-agent/tsconfig.json --noEmit",
    "dev:studio": "bun run --cwd packages/studio dev",
    "dev:harness": "bun run --cwd packages/canvas-agent harness",
    "dev:agent-viewer": "bun run --cwd packages/canvas-agent viewer"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
